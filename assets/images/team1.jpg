<svg width="350" height="350" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-team" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7c3aed;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow4">
      <feDropShadow dx="0" dy="4" stdDeviation="3" flood-opacity="0.3"/>
    </filter>
  </defs>
  <rect width="350" height="350" fill="url(#grad-team)"/>
  <circle cx="175" cy="175" r="100" fill="rgba(255,255,255,0.15)"/>
  <circle cx="175" cy="175" r="80" fill="rgba(255,255,255,0.1)"/>
  <circle cx="175" cy="130" r="50" fill="white" filter="url(#shadow4)"/>
  <text x="175" y="145" font-size="48" font-weight="bold" text-anchor="middle" fill="#7c3aed" font-family="Poppins">CO</text>
  <text x="175" y="230" font-size="24" font-weight="bold" text-anchor="middle" fill="white" font-family="Poppins">Chris Odhiambo</text>
  <text x="175" y="265" font-size="14" text-anchor="middle" fill="rgba(255,255,255,0.85)" font-family="Poppins">Founder & Lead Developer</text>
  <text x="175" y="295" font-size="12" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="Poppins">Full-stack software architect</text>
  <text x="175" y="315" font-size="12" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="Poppins">Expert in enterprise solutions</text>
</svg>
