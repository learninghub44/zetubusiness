<svg width="500" height="350" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-pos" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff6b35;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#cc3300;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow3">
      <feDropShadow dx="0" dy="4" stdDeviation="3" flood-opacity="0.3"/>
    </filter>
  </defs>
  <rect width="500" height="350" fill="url(#grad-pos)"/>
  <circle cx="90" cy="90" r="55" fill="rgba(255,255,255,0.1)"/>
  <circle cx="410" cy="280" r="85" fill="rgba(255,255,255,0.1)"/>
  <g transform="translate(180, 80)">
    <rect x="20" y="10" width="60" height="70" fill="white" filter="url(#shadow3)" rx="5"/>
    <rect x="25" y="20" width="50" height="35" fill="#ff6b35"/>
    <rect x="30" y="65" width="40" height="8" fill="#ccc"/>
  </g>
  <text x="250" y="210" font-size="40" font-weight="bold" text-anchor="middle" fill="white" font-family="Poppins">POS System</text>
  <text x="250" y="255" font-size="16" text-anchor="middle" fill="rgba(255,255,255,0.9)" font-family="Poppins">Smart Retail Management</text>
  <text x="250" y="290" font-size="14" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="Poppins">Inventory • Sales • Reporting • Multi-store</text>
</svg>
