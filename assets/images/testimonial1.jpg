<svg width="350" height="350" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-test1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff6b6b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ee5a3f;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow5">
      <feDropShadow dx="0" dy="4" stdDeviation="3" flood-opacity="0.3"/>
    </filter>
  </defs>
  <!-- Background -->
  <rect width="350" height="350" fill="url(#grad-test1)"/>
  <!-- Avatar -->
  <circle cx="175" cy="120" r="45" fill="white" filter="url(#shadow5)"/>
  <text x="175" y="135" font-size="40" font-weight="bold" text-anchor="middle" fill="#ff6b6b" font-family="Poppins">
    JD
  </text>
  <!-- Quote mark -->
  <text x="50" y="200" font-size="80" fill="rgba(255,255,255,0.2)" font-family="Georgia">
    "
  </text>
  <!-- Testimonial text -->
  <text x="175" y="230" font-size="14" text-anchor="middle" fill="white" font-family="Poppins" font-weight="500">
    Exceptional service! Zetu built our
  </text>
  <text x="175" y="250" font-size="14" text-anchor="middle" fill="white" font-family="Poppins" font-weight="500">
    entire e-commerce platform in just
  </text>
  <text x="175" y="270" font-size="14" text-anchor="middle" fill="white" font-family="Poppins" font-weight="500">
    3 months. Highly professional!
  </text>
  <!-- Stars -->
  <text x="175" y="305" font-size="16" text-anchor="middle" fill="#ffd700" font-family="Poppins">
    ★★★★★
  </text>
  <!-- Name -->
  <text x="175" y="330" font-size="13" font-weight="bold" text-anchor="middle" fill="white" font-family="Poppins">
    John Doe, CEO - TechMart
  </text>
</svg>
