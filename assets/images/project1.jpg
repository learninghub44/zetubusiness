<svg width="500" height="350" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-market" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00d4ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0099cc;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow">
      <feDropShadow dx="0" dy="4" stdDeviation="3" flood-opacity="0.3"/>
    </filter>
  </defs>
  <rect width="500" height="350" fill="url(#grad-market)"/>
  <circle cx="80" cy="60" r="50" fill="rgba(255,255,255,0.1)"/>
  <circle cx="420" cy="300" r="80" fill="rgba(255,255,255,0.1)"/>
  <g transform="translate(200, 100)">
    <path d="M 50 20 L 70 80 Q 70 90 60 90 L 40 90 Q 30 90 30 80 L 20 20 Z" fill="white" filter="url(#shadow)" stroke-width="2"/>
    <circle cx="40" cy="100" r="5" fill="white"/>
    <circle cx="60" cy="100" r="5" fill="white"/>
  </g>
  <text x="250" y="200" font-size="42" font-weight="bold" text-anchor="middle" fill="white" font-family="Poppins">E-Marketplace</text>
  <text x="250" y="245" font-size="16" text-anchor="middle" fill="rgba(255,255,255,0.9)" font-family="Poppins">Complete online selling platform</text>
  <text x="250" y="280" font-size="14" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="Poppins">Secure payments • Logistics • Analytics</text>
</svg>
