<svg width="500" height="350" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-hospital" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00ff88;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#00bb55;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow2">
      <feDropShadow dx="0" dy="4" stdDeviation="3" flood-opacity="0.3"/>
    </filter>
  </defs>
  <rect width="500" height="350" fill="url(#grad-hospital)"/>
  <circle cx="100" cy="80" r="60" fill="rgba(255,255,255,0.1)"/>
  <circle cx="380" cy="270" r="90" fill="rgba(255,255,255,0.1)"/>
  <g transform="translate(200, 90)">
    <rect x="35" y="20" width="30" height="80" fill="white" filter="url(#shadow2)"/>
    <rect x="15" y="45" width="70" height="30" fill="white"/>
  </g>
  <text x="250" y="210" font-size="38" font-weight="bold" text-anchor="middle" fill="white" font-family="Poppins">HMS System</text>
  <text x="250" y="255" font-size="16" text-anchor="middle" fill="rgba(255,255,255,0.9)" font-family="Poppins">Hospital Management Solution</text>
  <text x="250" y="290" font-size="14" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="Poppins">Patient • Pharmacy • Lab integration</text>
</svg>
